// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Escopo da role (plataforma ou organizacao)
enum RoleScope {
  PLATFORM     // Role global da plataforma (organizationId = null)
  ORGANIZATION // Role especifica de uma organizacao
}

// Permissoes do sistema (fixas)
enum Permission {
  // Threads
  THREADS_READ
  THREADS_WRITE
  THREADS_DELETE
  // Agentes
  AGENTS_READ
  AGENTS_WRITE
  AGENTS_DELETE
  // Membros
  MEMBERS_READ
  MEMBERS_INVITE
  MEMBERS_MANAGE
  // Roles
  ROLES_READ
  ROLES_MANAGE
  // Organizacao
  ORGANIZATION_MANAGE
  // Plataforma (para roles de plataforma no futuro)
  PLATFORM_MANAGE
  // Prompts
  PROMPTS_READ
  PROMPTS_WRITE
  PROMPTS_DELETE
}

// Role do prompt (para IA)
enum PromptRole {
  SYSTEM
  USER
  ASSISTANT
}

// Provedor de modelos de IA
enum ModelProvider {
  OPENAI
  OPENROUTER
  ANTHROPIC
  GOOGLE
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  memberships     OrganizationMember[]
  invitesCreated  OrganizationInvite[] @relation("InvitesCreated")
  invitesAccepted OrganizationInvite[] @relation("InvitesAccepted")

  @@map("users")
}

model Organization {
  id                   String         @id @default(uuid())
  name                 String
  slug                 String         @unique
  defaultModelProvider ModelProvider? @map("default_model_provider")
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")

  members        OrganizationMember[]
  roles          Role[]
  invites        OrganizationInvite[]
  threads        Thread[]
  prompts        Prompt[]
  modelProviders OrganizationModelProvider[]

  @@map("organizations")
}

// Configuracoes de provedores de modelos por organizacao
model OrganizationModelProvider {
  id             String        @id @default(uuid())
  organizationId String        @map("organization_id")
  provider       ModelProvider
  apiKey         String        @map("api_key")
  isActive       Boolean       @default(true) @map("is_active")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, provider])
  @@map("organization_model_providers")
}

// Roles unificadas (plataforma e organizacao)
model Role {
  id             String    @id @default(uuid())
  organizationId String?   @map("organization_id") // null = role de plataforma
  scope          RoleScope @default(ORGANIZATION)
  name           String
  description    String?
  isSystemRole   Boolean   @default(false) @map("is_system_role")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization Organization?        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  permissions  RolePermission[]
  members      OrganizationMember[]
  invites      OrganizationInvite[]

  @@unique([organizationId, name])
  @@map("roles")
}

// Permissoes atribuidas a cada role
model RolePermission {
  id         String     @id @default(uuid())
  roleId     String     @map("role_id")
  permission Permission
  createdAt  DateTime   @default(now()) @map("created_at")

  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permission])
  @@map("role_permissions")
}

model OrganizationMember {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  organizationId String   @map("organization_id")
  roleId         String   @map("role_id")
  isOwner        Boolean  @default(false) @map("is_owner")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role         Role         @relation(fields: [roleId], references: [id])
  threads      Thread[]
  prompts      Prompt[]

  @@unique([userId, organizationId])
  @@map("organization_members")
}

// Threads de conversa
model Thread {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  createdById    String   @map("created_by_id")
  title          String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    OrganizationMember @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@map("threads")
}

// Prompts salvos
model Prompt {
  id             String     @id @default(uuid())
  organizationId String     @map("organization_id")
  createdById    String     @map("created_by_id")
  name           String
  content        String     @db.Text
  role           PromptRole @default(SYSTEM)
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    OrganizationMember @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@map("prompts")
}

// Convites para organizacao
model OrganizationInvite {
  id             String    @id @default(uuid())
  organizationId String    @map("organization_id")
  roleId         String    @map("role_id")
  token          String    @unique
  createdById    String    @map("created_by_id")
  expiresAt      DateTime  @map("expires_at")
  usedAt         DateTime? @map("used_at")
  usedById       String?   @map("used_by_id")
  createdAt      DateTime  @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role         Role         @relation(fields: [roleId], references: [id])
  createdBy    User         @relation("InvitesCreated", fields: [createdById], references: [id])
  usedBy       User?        @relation("InvitesAccepted", fields: [usedById], references: [id])

  @@map("organization_invites")
}
